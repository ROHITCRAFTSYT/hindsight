# ───────────────────────────────────────────────────────────────
# Hindsight configuration. Copy to backend/.env and fill in ONE mode.
# ───────────────────────────────────────────────────────────────

# ── Mode A: Cognee Cloud (recommended — the hackathon Cloud track) ──
# Sign up at https://platform.cognee.ai and redeem the free Developer
# plan with code COGNEE-35, then create an API key. Hindsight talks to
# the Cognee Cloud REST API directly (X-Api-Key auth).
COGNEE_CLOUD_API_KEY=
# Base URL of the Cognee Cloud service. Confirm the exact host shown in
# your platform.cognee.ai dashboard; this is the default guess.
COGNEE_SERVICE_URL=https://api.cognee.ai

# ── Mode B: Self-hosted / open source (embedded Cognee SDK) ──
# Only an LLM key is required; Cognee runs locally with no extra services.
# Example uses Groq (fast, free tier). Requires `pip install cognee[groq]`.
# LLM_API_KEY=
# LLM_PROVIDER=groq
# LLM_MODEL=groq/llama-3.3-70b-versatile

# ── Mode C: Demo mode (no keys; in-memory mock for instant clicking) ──
# Set to true to force the zero-dependency demo. If left false but no keys
# are detected above, Hindsight auto-enables demo mode anyway.
DEMO_MODE=false

# ── Shared ──
# Dataset Hindsight reads/writes by default (used for graph + forget).
DEFAULT_DATASET=main

# ── Server ──
HINDSIGHT_PORT=8000
# Comma-separated origins allowed by CORS (the Vite dev server by default)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
